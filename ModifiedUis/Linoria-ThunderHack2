    }, true);

    pcall(NotifyOuter.TweenSize, NotifyOuter, UDim2.new(0, XSize + 8 + 4, 0, YSize), 'Out', Library.Notification.In, Library.Notification.Lerp, true);

    task.spawn(function()
        wait(Time or 5);

        pcall(NotifyOuter.TweenSize, NotifyOuter, UDim2.new(0, 0, 0, YSize), 'Out', Library.Notification.Out, Library.Notification.Lerp, true);

        wait(Library.Notification.Lerp);

        NotifyOuter:Destroy();
    end);
